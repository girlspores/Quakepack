# Apply the dynamically assigned color to the ancient team
# Reads from: ancient color.Global
# Sets: team modify ancient color [colorname]
# Sets: scoreboard objectives setdisplay sidebar.team.[colorname] kills.Ancient

execute if score ancient color.Global matches 1 run team modify ancient color black
execute if score ancient color.Global matches 1 run scoreboard objectives setdisplay sidebar.team.black kills.Ancient

execute if score ancient color.Global matches 2 run team modify ancient color dark_blue
execute if score ancient color.Global matches 2 run scoreboard objectives setdisplay sidebar.team.dark_blue kills.Ancient

